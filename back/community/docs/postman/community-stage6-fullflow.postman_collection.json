              "mode": "raw",
              "raw": "{\n  \"title\": \"{{activityTitle}}\",\n  \"content\": \"# Stage6 Activity\\nplease join\",\n  \"coverFileId\": {{activityFileId}},\n  \"attachmentJson\": \"{{activityAttachmentJson}}\",\n  \"activityStartTime\": \"{{activityStartTime}}\",\n  \"activityEndTime\": \"{{activityEndTime}}\",\n  \"signupStartTime\": \"{{signupStartTime}}\",\n  \"signupEndTime\": \"{{signupEndTime}}\",\n  \"location\": \"hall-a\",\n  \"maxParticipants\": 30,\n  \"scopeItems\": [{\"scopeType\": \"COMPLEX\", \"scopeRefId\": {{complexOrgId}}}]\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const now = new Date();",
                  "const fmt = d => d.toISOString().slice(0, 19);",
                  "pm.environment.set('signupStartTime', fmt(new Date(now.getTime() - 10 * 60 * 1000)));",
                  "pm.environment.set('signupEndTime', fmt(new Date(now.getTime() + 2 * 24 * 60 * 60 * 1000)));",
                  "pm.environment.set('activityStartTime', fmt(new Date(now.getTime() + 3 * 24 * 60 * 60 * 1000)));",
                  "pm.environment.set('activityEndTime', fmt(new Date(now.getTime() + 3 * 24 * 60 * 60 * 1000 + 2 * 60 * 60 * 1000)));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.expect(pm.response.json().code).to.eql(0);"
                ]
              }
            }
          ]
        },

{
  "info": {
    "_postman_id": "4cfa8a89-6ad9-4db9-8303-592fced64f73",
    "name": "community-stage6-fullflow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Stage6 full-flow collection. Run in this order: Auth -> Storage -> Upload -> Notice -> Activity -> UserRole -> Repair -> Org -> Logs."
  },
  "item": [
    {
      "name": "认证",
      "item": [
        {
          "name": "01-admin-login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/auth/login",
            "description": "Pre: none. Assert: HTTP 200, code=0, save adminToken and run variables.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUsername}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.response.to.have.status(200);",
                  "const body = pm.response.json();",
                  "pm.expect(body.code).to.eql(0);",
                  "pm.environment.set('adminToken', body.data.accessToken);",
                  "const d = new Date();",
                  "const p = n => String(n).padStart(2, '0');",
                  "const suffix = d.getFullYear().toString().slice(-2) + p(d.getMonth() + 1) + p(d.getDate()) + p(d.getHours()) + p(d.getMinutes()) + p(d.getSeconds());",
                  "pm.environment.set('residentUsername', `resident_stage6_${suffix}`);",
                  "pm.environment.set('residentPhone', `1399${Math.floor(Math.random() * 9000000 + 1000000)}`);",
                  "pm.environment.set('noticeTitle', `stage6_notice_${suffix}`);",
                  "pm.environment.set('activityTitle', `stage6_activity_${suffix}`);",
                  "pm.environment.set('repairTitle', `stage6_repair_${suffix}`);",
                  "pm.environment.set('propAdminUsername', `prop_admin_${suffix}`);",
                  "pm.environment.set('maintUsername', `maint_${suffix}`);"
                ]
              }
            }
          ]
        },

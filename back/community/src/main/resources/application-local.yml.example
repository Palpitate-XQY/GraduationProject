spring:
  datasource:
    driver-class-name: com.mysql.cj.jdbc.Driver
    url: jdbc:mysql://127.0.0.1:3306/community_service?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: root
    password: your-password
  data:
    redis:
      host: 127.0.0.1
      port: 6379
      password:
      database: 0

community:
  jwt:
    secret: your-32-byte-or-longer-secret
    expire-minutes: 120
    issuer: community-service
  file-storage:
    default-type: LOCAL
    local-base-path: ./storage
    local-access-base-url: /api/files
    max-file-size-bytes: 20971520

# 生产建议通过“系统管理-文件存储配置”接口维护七牛配置，而非写在 yml 中

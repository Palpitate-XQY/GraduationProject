<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xxqqyyy.community.modules.file.mapper.BizFileInfoMapper">

    <resultMap id="BizFileInfoMap" type="xxqqyyy.community.modules.file.entity.BizFileInfo">
        <id property="id" column="id"/>
        <result property="bizType" column="biz_type"/>
        <result property="bizId" column="biz_id"/>
        <result property="storageType" column="storage_type"/>
        <result property="fileName" column="file_name"/>
        <result property="originFileName" column="origin_file_name"/>
        <result property="filePath" column="file_path"/>
        <result property="fileSize" column="file_size"/>
        <result property="contentType" column="content_type"/>
        <result property="uploaderId" column="uploader_id"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="updateBy" column="update_by"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
        <result property="version" column="version"/>
    </resultMap>

    <sql id="base_columns">
        id, biz_type, biz_id, storage_type, file_name, origin_file_name, file_path, file_size, content_type, uploader_id,
        create_by, create_time, update_by, update_time, deleted, version
    </sql>

    <insert id="insert" parameterType="xxqqyyy.community.modules.file.entity.BizFileInfo" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO biz_file_info (
            biz_type, biz_id, storage_type, file_name, origin_file_name, file_path, file_size, content_type, uploader_id,
            create_by, create_time, update_by, update_time, deleted, version
        ) VALUES (
            #{bizType}, #{bizId}, #{storageType}, #{fileName}, #{originFileName}, #{filePath}, #{fileSize}, #{contentType}, #{uploaderId},
            #{createBy}, NOW(), #{updateBy}, NOW(), 0, 0
        )
    </insert>

    <select id="selectById" resultMap="BizFileInfoMap">
        SELECT <include refid="base_columns"/>
        FROM biz_file_info
        WHERE id = #{id}
          AND deleted = 0
        LIMIT 1
    </select>

    <select id="selectByIds" resultMap="BizFileInfoMap">
        SELECT <include refid="base_columns"/>
        FROM biz_file_info
        WHERE deleted = 0
          <if test="ids != null and ids.size() > 0">
              AND id IN
              <foreach collection="ids" item="id" open="(" separator="," close=")">
                  #{id}
              </foreach>
          </if>
          <if test="ids == null or ids.size() == 0">
              AND 1 = 2
          </if>
    </select>

    <update id="updateBizBind">
        UPDATE biz_file_info
        SET biz_type = #{bizType},
            biz_id = #{bizId},
            update_by = #{updateBy},
            update_time = NOW()
        WHERE id = #{id}
          AND deleted = 0
    </update>

</mapper>


<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xxqqyyy.community.modules.repair.mapper.BizRepairAttachmentMapper">

    <resultMap id="RepairAttachmentMap" type="xxqqyyy.community.modules.repair.entity.BizRepairAttachment">
        <id property="id" column="id"/>
        <result property="repairOrderId" column="repair_order_id"/>
        <result property="fileId" column="file_id"/>
        <result property="attachmentType" column="attachment_type"/>
        <result property="createBy" column="create_by"/>
        <result property="createTime" column="create_time"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <insert id="batchInsert">
        INSERT INTO biz_repair_attachment (
            repair_order_id, file_id, attachment_type, create_by, create_time, deleted
        ) VALUES
        <foreach collection="list" item="item" separator=",">
            (
                #{item.repairOrderId}, #{item.fileId}, #{item.attachmentType}, #{item.createBy}, NOW(), 0
            )
        </foreach>
    </insert>

    <select id="selectByRepairOrderId" resultMap="RepairAttachmentMap">
        SELECT id, repair_order_id, file_id, attachment_type, create_by, create_time, deleted
        FROM biz_repair_attachment
        WHERE repair_order_id = #{repairOrderId}
          AND deleted = 0
        ORDER BY id ASC
    </select>

</mapper>
